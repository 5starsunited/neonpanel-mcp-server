{
  "name": "brand_analytics_analyze_search_catalog_performance",
  "description": "Analyzes Search Catalog Performance using the Brand Analytics catalog performance report. Returns KPI metrics, trend deltas, and 4 high-level RYG signals (strength, weakness, opportunity, threshold) with explanations. Supports filtering by classification and signal colors.",
  "isConsequential": false,
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "object",
        "description": "Shared query envelope for Brand Analytics tools.",
        "properties": {
          "filters": {
            "type": "object",
            "description": "WHERE clause filters. company_ids is required.",
            "properties": {
              "company_ids": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 1
                },
                "minItems": 1,
                "description": "Company identifier(s) - required for multi-tenant isolation."
              },
              "asins": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Optional: filter by child ASINs."
              },
              "parent_asins": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Optional: filter by parent ASINs."
              },
              "marketplaces": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Amazon marketplace code(s) (e.g., 'US', 'UK', 'DE'). Multiple markets supported."
              },
              "row_type": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "child",
                    "parent"
                  ]
                },
                "description": "Optional: restrict to child or parent rows."
              },
              "revenue_abcd_class": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "A",
                    "B",
                    "C",
                    "D"
                  ]
                },
                "default": [
                  "A",
                  "B"
                ],
                "description": "Filter by revenue classification (A=top 70%, B=next 20%, C=next 8%, D=bottom 2%). Default: A,B."
              },
              "pareto_abc_class": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "A",
                    "B",
                    "C"
                  ]
                },
                "description": "Filter by Pareto classification (A=top 80%, B=next 15%, C=bottom 5%)."
              },
              "strength_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by strength signal color."
              },
              "weakness_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by weakness signal color."
              },
              "opportunity_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by opportunity signal color."
              },
              "threshold_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by threshold signal color."
              },
              "click_trend_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by click rate trend signal color."
              },
              "cart_add_trend_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by cart add rate trend signal color."
              },
              "purchase_trend_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by purchase rate trend signal color."
              }
            },
            "required": [
              "company_ids"
            ],
            "additionalProperties": false
          },
          "aggregation": {
            "type": "object",
            "properties": {
              "time": {
                "type": "object",
                "properties": {
                  "start_date": {
                    "type": "string",
                    "format": "date"
                  },
                  "end_date": {
                    "type": "string",
                    "format": "date"
                  },
                  "periods_back": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 52,
                    "default": 12
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "sort": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string",
                "enum": [
                  "week_start",
                  "impressiondata_impressioncount",
                  "clickdata_clickcount",
                  "purchasedata_purchasecount",
                  "kpi_click_rate",
                  "kpi_cart_add_rate",
                  "kpi_purchase_rate",
                  "purchasedata_searchtrafficsales_amount"
                ],
                "default": "week_start"
              },
              "direction": {
                "type": "string",
                "enum": [
                  "asc",
                  "desc"
                ],
                "default": "desc"
              }
            },
            "additionalProperties": false
          },
          "select_fields": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "week_start",
                "company_id",
                "marketplace",
                "marketplace_country_code",
                "parent_asin",
                "asin",
                "row_type",
                "brand",
                "title",
                "revenue_abcd_class",
                "pareto_abc_class",
                "product_family",
                "revenue_share",
                "impressiondata_impressioncount",
                "clickdata_clickcount",
                "cartadddata_cartaddcount",
                "purchasedata_purchasecount",
                "clickdata_clickrate",
                "purchasedata_conversionrate",
                "purchasedata_searchtrafficsales_amount",
                "purchasedata_searchtrafficsales_currencycode",
                "kpi_click_rate",
                "kpi_cart_add_rate",
                "kpi_purchase_rate",
                "kpi_sales_per_click",
                "kpi_sales_per_impression",
                "kpi_click_rate_wow",
                "kpi_click_rate_wolast4",
                "kpi_click_rate_wolast12",
                "kpi_cart_add_rate_wow",
                "kpi_cart_add_rate_wolast4",
                "kpi_cart_add_rate_wolast12",
                "kpi_purchase_rate_wow",
                "kpi_purchase_rate_wolast4",
                "kpi_purchase_rate_wolast12",
                "cvr_same_day",
                "cvr_one_day",
                "cvr_two_day",
                "cvr_same_vs_two_ratio",
                "cvr_one_vs_two_ratio",
                "kpi_click_rate_trend_signal",
                "kpi_cart_add_rate_trend_signal",
                "kpi_purchase_rate_trend_signal",
                "strength_signal",
                "weakness_signal",
                "opportunity_signal",
                "threshold_signal",
                "strength_color",
                "weakness_color",
                "opportunity_color",
                "threshold_color"
              ]
            },
            "description": "Optional output field selection. When provided, only these fields are returned per row — significantly reduces response size. If omitted, returns all columns (~90 fields). IMPORTANT: Use exact field names from the enum."
          },
          "ryg_company_id": {
            "type": "integer",
            "minimum": 1,
            "description": "Optional: company_id whose custom RYG thresholds to apply. If omitted, uses the first company_id from filters. If the company has no custom thresholds, system defaults are used."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        },
        "required": [
          "filters"
        ],
        "additionalProperties": false
      }
    },
    "required": [
      "query"
    ],
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "week_start": {
              "type": "string",
