{
  "name": "brand_analytics_analyze_search_query_performance",
  "description": "Analyzes Search Query Performance (SQP) using a precomputed snapshot. Returns KPI metrics, deltas, efficiency ratios (click-through and conversion), diagnostic scenario classification (A: visibility, B: creative, C: conversion, D: protect), term type (branded/generic/long_tail), priority tier (1-4), and RYG signals. Supports filtering by all computed dimensions.",
  "isConsequential": false,
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "object",
        "description": "Shared query envelope for Brand Analytics tools.",
        "properties": {
          "filters": {
            "type": "object",
            "description": "WHERE clause filters. company_ids is required.",
            "properties": {
              "company_ids": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 1
                },
                "minItems": 1,
                "description": "Company identifier(s) - required for multi-tenant isolation. Single company: [103], Portfolio analysis: [103, 104]."
              },
              "search_terms": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Optional: filter by search queries."
              },
              "parent_asins": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Optional: filter by parent ASINs."
              },
              "asins": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Optional: filter by child ASINs."
              },
              "marketplaces": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Amazon marketplace code(s) (e.g., 'US', 'UK', 'DE'). Multiple markets supported."
              },
              "row_type": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "child",
                    "parent"
                  ]
                },
                "description": "Optional: restrict to child or parent rows."
              },
              "revenue_abcd_class": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "A",
                    "B",
                    "C",
                    "D"
                  ]
                },
                "default": [
                  "A",
                  "B"
                ],
                "description": "Filter by revenue classification (A=top 70%, B=next 20%, C=next 8%, D=bottom 2%). Default: A,B."
              },
              "pareto_abc_class": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "A",
                    "B",
                    "C"
                  ]
                },
                "description": "Filter by Pareto classification (A=top 80%, B=next 15%, C=bottom 5%)."
              },
              "strength_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by strength signal color."
              },
              "weakness_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by weakness signal color."
              },
              "opportunity_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by opportunity signal color."
              },
              "threshold_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by threshold signal color."
              },
              "impression_trend_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by impression share trend signal color."
              },
              "click_trend_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by click share trend signal color."
              },
              "cart_add_trend_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by cart add rate trend signal color."
              },
              "purchase_trend_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by purchase rate trend signal color."
              },
              "ctr_advantage_trend_colors": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red"
                  ]
                },
                "description": "Filter by CTR advantage trend signal color."
              },
              "diagnostic_scenarios": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "A_visibility",
                    "B_creative",
                    "C_conversion",
                    "D_protect",
                    "insufficient_data"
                  ]
                },
                "description": "Filter by diagnostic scenario. A=low visibility (fix ads/SEO), B=visual competition (fix main image/title), C=listing conversion (fix detail page), D=healthy funnel (protect & scale)."
              },
              "term_types": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "branded",
                    "generic",
                    "long_tail"
                  ]
                },
                "description": "Filter by search term type. branded=contains your brand name (expect 70%+ BCS), generic=category terms (main competitive battleground), long_tail=4+ words (high intent, often most profitable)."
              },
              "priority_tiers": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 4
                },
                "description": "Filter by priority tier. 1=high vol+strong conversion (defend), 2=high vol+underperforming (highest ROI fix), 3=low vol+strong efficiency (profit harvest), 4=low vol+weak (deprioritize)."
              }
            },
            "required": [
              "company_ids"
            ],
            "additionalProperties": false
          },
          "aggregation": {
            "type": "object",
            "properties": {
              "time": {
                "type": "object",
                "properties": {
                  "start_date": {
                    "type": "string",
                    "format": "date"
                  },
                  "end_date": {
                    "type": "string",
                    "format": "date"
                  },
                  "periods_back": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 52,
                    "default": 12
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "sort": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string",
                "enum": [
                  "week_start",
                  "searchquerydata_searchqueryscore",
                  "kpi_impression_share",
                  "kpi_click_share",
                  "kpi_cart_add_rate",
                  "kpi_purchase_rate"
                ],
                "default": "week_start"
              },
              "direction": {
                "type": "string",
                "enum": [
                  "asc",
                  "desc"
                ],
                "default": "desc"
              }
            },
            "additionalProperties": false
          },
          "select_fields": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "week_start",
                "company_id",
                "marketplace_country_code",
                "marketplace",
                "parent_asin",
                "asin",
                "row_type",
                "brand",
                "title",
                "revenue_abcd_class",
                "pareto_abc_class",
                "product_family",
                "revenue_share",
                "searchquerydata_searchquery",
                "searchquerydata_searchqueryscore",
                "searchquerydata_searchqueryvolume",
                "kpi_impression_share",
                "kpi_click_share",
                "kpi_cart_add_rate",
                "kpi_purchase_rate",
                "kpi_ctr_advantage",
                "kpi_impression_share_wow",
                "kpi_impression_share_wolast4",
                "kpi_impression_share_wolast12",
                "kpi_click_share_wow",
                "kpi_click_share_wolast4",
                "kpi_click_share_wolast12",
                "kpi_cart_add_rate_wow",
                "kpi_cart_add_rate_wolast4",
                "kpi_cart_add_rate_wolast12",
                "kpi_purchase_rate_wow",
                "kpi_purchase_rate_wolast4",
                "kpi_purchase_rate_wolast12",
                "kpi_ctr_advantage_wow",
                "kpi_ctr_advantage_wolast4",
                "kpi_ctr_advantage_wolast12",
                "cvr_same_day",
                "cvr_one_day",
                "cvr_two_day",
                "cvr_same_vs_two_ratio",
                "cvr_one_vs_two_ratio",
                "kpi_impression_share_trend_signal",
                "kpi_click_share_trend_signal",
                "kpi_cart_add_rate_trend_signal",
                "kpi_purchase_rate_trend_signal",
                "kpi_ctr_advantage_trend_signal",
                "strength_signal",
                "weakness_signal",
                "opportunity_signal",
                "threshold_signal",
                "strength_color",
                "weakness_color",
                "opportunity_color",
                "threshold_color",
                "click_through_efficiency",
                "conversion_efficiency",
                "term_type",
                "diagnostic_scenario",
                "diagnostic_scenario_description",
                "diagnostic_scenario_action",
                "diagnostic_scenario_signal",
                "priority_tier",
                "priority_tier_description",
                "impressiondata_totalqueryimpressioncount",
                "impressiondata_asinimpressioncount",
                "impressiondata_asinimpressionshare",
                "clickdata_totalclickcount",
                "clickdata_asinclickcount",
                "clickdata_asinclickshare",
                "cartadddata_totalcartaddcount",
                "cartadddata_asincartaddcount",
                "cartadddata_asincartaddshare",
                "purchasedata_totalpurchasecount",
                "purchasedata_asinpurchasecount",
                "purchasedata_asinpurchaseshare",
                "startdate",
                "enddate"
              ]
            },
            "description": "Optional output field selection. When provided, only these fields are returned per row — significantly reduces response size. If omitted, returns all columns (~100 fields). IMPORTANT: Use exact field names from the enum — e.g., 'searchquerydata_searchquery' not 'search_query'."
          },
          "ryg_company_id": {
            "type": "integer",
            "minimum": 1,
            "description": "Optional: company_id whose custom RYG thresholds to apply. If omitted, uses the first company_id from filters. If the company has no custom thresholds, system defaults are used."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        },
        "required": [
          "filters"
        ],
        "additionalProperties": false
      }
    },
    "required": [
      "query"
    ],
    "additionalProperties": false
  },
